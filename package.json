{
  "name": "lacuna",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Lacuna - a local-only FSRS-6 flashcard revision application.",
  "scripts": {
    "start": "vite",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
