    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@open-spaced-repetition/binding": "^0.4.0",
    "@open-spaced-repetition/binding-wasm32-wasi": "^0.4.0",
    "dexie": "^4.0.10",
    "dexie-react-hooks": "^1.1.7",
    "katex": "^0.16.11",
    "motion": "^11.15.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "react-router-dom": "^6.28.0",
    "recharts": "^2.13.3",
    "rehype-highlight": "^7.0.1",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.0",
    "remark-math": "^6.0.0",
    "ts-fsrs": "^5.2.3"
  },
  "overrides": {
    "nanoid": "3.3.11",
